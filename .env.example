# Copiez ce fichier en ".env" et remplissez les valeurs.

# Token du bot Discord (obligatoire)
DISCORD_TOKEN=votre_token_ici

# Préfixe des commandes (optionnel, "§" par défaut)
COMMAND_PREFIX=§

# ID du serveur pour synchroniser les commandes slash instantanément
# pendant le développement (optionnel). Laissez vide pour une
# synchronisation globale (peut prendre jusqu'à 1h).
GUILD_ID=

# ID de l'owner principal du bot. Cet owner a tous les droits et ne peut
# pas être retiré via la commande rmowner. Les owners additionnels sont
# gérés via addowner / rmowner (stockés dans owners.json).
OWNER_ID=votre_id_discord_ici

# --- Panel web (optionnel) ------------------------------------------------
# Renseignez CLIENT_ID et CLIENT_SECRET (portail développeur Discord >
# OAuth2) pour activer le panel web d'administration. Ajoutez l'URL de
# redirection ci-dessous dans les "Redirects" de l'application Discord.
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
OAUTH_REDIRECT_URI=http://localhost:8080/callback
WEB_HOST=0.0.0.0
WEB_PORT=8080
# Secret de signature des sessions (généré automatiquement si vide).
WEB_SECRET=
